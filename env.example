# ── JAGGER OS · Environment Variables ──────────────────────────────────────
# Copy this file to .env.local and fill in the values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Gemini AI (for /api/ai-summary)
GEMINI_API_KEY=your_gemini_api_key

# Payment Mock (set to "true" to bypass Newebpay and write directly to DB)
PAYMENT_MOCK=true

# Resend email (for /api/notify)
RESEND_API_KEY=your_resend_api_key
ADMIN_EMAIL=admin@yourdomain.com

# Google Drive Service Account (already configured in /api/portfolio)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GOOGLE_DRIVE_FOLDER_ID=your_root_folder_id

# Site URL (used in email CTAs)
NEXT_PUBLIC_SITE_URL=https://jaggersu.com

# 藍新金流 (for /api/checkout)
# 測試環境: https://ccore.newebpay.com/MPG/mpg_gateway
# 正式環境: https://core.newebpay.com/MPG/mpg_gateway
NEWEBPAY_MERCHANT_ID=your_merchant_id
NEWEBPAY_HASH_KEY=your_hash_key
NEWEBPAY_HASH_IV=your_hash_iv
NEWEBPAY_URL=https://ccore.newebpay.com/MPG/mpg_gateway

# Supabase Service Role Key (for webhook admin access, bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
